# NATS
NATS_URL=nats://127.0.0.1:4223
NATS_USERNAME=
NATS_PASSWORD=

# NATS TLS (production only)
NATS_TLS_CLIENT_CERT=
NATS_TLS_CLIENT_KEY=
NATS_TLS_CA_CERT=

# Consul
CONSUL_ADDRESS=localhost:8501
CONSUL_USERNAME=
CONSUL_PASSWORD=
CONSUL_TOKEN=
# Consul TLS (production only) — omit to use default paths: certs/consul-{client-cert,client-key,rootCA}.pem
CONSUL_TLS_CLIENT_CERT=
CONSUL_TLS_CLIENT_KEY=
CONSUL_TLS_CA_CERT=

# App
ENVIRONMENT=development
BADGER_PASSWORD=your-secure-password-here
BADGER_BACKUP_PASSWORD=your-secure-password-here
CHAIN_CODE=your-32-byte-hex-chain-code-here  # generate: openssl rand -hex 32

# Event Initiator
EVENT_INITIATOR_ALGORITHM=ed25519
EVENT_INITIATOR_PUBKEY=your-ed25519-public-key-hex

# Storage
DB_PATH=.
BACKUP_ENABLED=true
BACKUP_PERIOD_SECONDS=300
BACKUP_DIR=backups

# MPC
MPC_THRESHOLD=2
MAX_CONCURRENT_KEYGEN=2
MAX_CONCURRENT_SIGNING=10

# Health Check
HEALTHCHECK_ENABLED=false
HEALTHCHECK_ADDRESS=0.0.0.0:8080
